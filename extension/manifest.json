{
  "manifest_version": 3,
  "name": "PR Preview — Vercel",
  "description": "Abre o preview deploy do Vercel direto na página do Pull Request no GitHub.",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://api.vercel.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["vercel-api.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PR Preview — Vercel"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
